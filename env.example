# Supabase - get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM service - used by /explain endpoints
# OpenAI-compatible example: https://api.openai.com/v1/chat/completions
# Ollama local example: http://localhost:11434/api/generate
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=llama3.2:3b

# Optional: direct DB URL, not required if using the Supabase client
DATABASE_URL=
