# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional regex for local dev ports such as Vite's 5173, 5174, etc.
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):\d+$

# LLM Integration (optional, leave empty if not using explanation generation)
LLM_API_URL=https://your-llm-api.example.com/v1/completions
LLM_API_KEY=your-llm-api-key-here

# Database URL (optional, alternative to Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/lgu_risk_scanner

# Application Settings
APP_NAME=lgu-risk-scanner
